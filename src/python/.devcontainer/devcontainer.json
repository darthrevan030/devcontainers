{
  "name": "Python",
  "image": "mcr.microsoft.com/devcontainers/python:3.14",
  "features": {
    "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {},
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
      "moby": false
    },
    "ghcr.io/w3cj/devcontainer-features/firewall:latest": {
      "githubIps": true,
      "claudeCode": true
    }
  },
  "mounts": [
    "source=${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached"
  ],
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.isort",
        "ms-python.debugpy",
        "ms-toolsai.jupyter",
        "usernamehw.errorlens",
        "gruntfuggly.todo-tree",
        "mhutchie.git-graph",
        "streetsidesoftware.code-spell-checker",
        "anthropic.claude-code",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "mtxr.sqltools-driver-sqlite",
        "alexcvzz.vscode-sqlite",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.fontSize": 16,
        "editor.formatOnSave": true,
        "editor.wordWrap": "off",
        "editor.inlayHints.enabled": "off",
        "editor.guides.indentation": false,
        "editor.guides.bracketPairs": false,
        "python.analysis.typeCheckingMode": "basic",
        "python.terminal.useEnvFile": true,
        "sqltools.useNodeRuntime": false,
        "[python]": {
          "editor.defaultFormatter": "ms-python.python",
          "editor.tabSize": 4
        }
      }
    }
  },
  "forwardPorts": [5432],
  "postCreateCommand": "[ -f requirements.txt ] && pip install -r requirements.txt || true && sudo chown -R vscode:vscode ~/.claude && chmod 700 ~/.claude && chmod 600 ~/.claude/.credentials.json"
}